{
  "name": "pragma-so",
  "version": "0.1.6",
  "description": "Very minimal pragma-so CLI",
  "main": "dist/cli/index.js",
  "bin": {
    "pragma-so": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run ui:build",
    "prepack": "npm run build",
    "start": "node dist/cli/index.js",
    "ui:dev": "vite --config ui/vite.config.mjs ui",
    "ui:build": "vite build --config ui/vite.config.mjs ui",
    "ui:preview": "vite preview --config ui/vite.config.mjs ui"
  },
  "files": [
    "dist",
    "ui/dist"
  ],
  "keywords": [
    "cli",
    "commander",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@types/mime-types": "^3.0.1",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "eventsource-parser": "^3.0.6",
    "execa": "^5.1.1",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.7",
    "lucide-react": "^0.577.0",
    "mime-types": "^3.0.2",
    "open": "^8.4.2",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.11"
  }
}
